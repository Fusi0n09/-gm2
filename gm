-- ANGEL WINGS (save after death, velocity-based flap)
-- ============================================================
local gm_wings_enabled = false
local gm_wings_connection = nil
local gm_wings_cfg = {
    speed = 0.8,       -- animation speed multiplier
    flapAngle = 10,    -- max flap angle in degrees
    twistAngle = 3,    -- max twist angle in degrees
    velocityEffect = true, -- speed up flap when moving
}

local function gm_applywings(char)
    if not gm_wings_enabled then return end
    pcall(function()
        local rs2 = game:GetService("ReplicatedStorage")
        local run2 = game:GetService("RunService")
        local torso = char:WaitForChild("UpperTorso", 5)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not torso or not hrp then return end

        local existing = char:FindFirstChild("Angel Wings")
        if existing then existing:Destroy() end

        local equipable = rs2:WaitForChild("EquipableItem", 5)
        if not equipable then return end
        local wingModel = equipable:WaitForChild("Angel Wings", 5)
        if not wingModel then return end

        local wing = wingModel:Clone()
        wing.Parent = char

        local handle = wing:WaitForChild("Handle", 5)
        if not handle then wing:Destroy() return end
        handle.Anchored = false
        handle.CanCollide = false

        local m = Instance.new("Motor6D")
        m.Part0 = torso
        m.Part1 = handle
        m.C0 = CFrame.new(0, 0, 0)
        m.Parent = torso

        local t = 0
        if gm_wings_connection then gm_wings_connection:Disconnect() end
        gm_wings_connection = run2.RenderStepped:Connect(function(dt)
            if not gm_wings_enabled or not char.Parent then
                gm_wings_connection:Disconnect()
                return
            end
            t += dt * gm_wings_cfg.speed
            local speedMult = gm_wings_cfg.velocityEffect and math.clamp(hrp.Velocity.Magnitude / 10, 0, 1) or 0
            local flap = math.sin(t * 1.5) * math.rad(gm_wings_cfg.flapAngle) * (0.5 + speedMult)
            local twist = math.sin(t * 1.8) * math.rad(gm_wings_cfg.twistAngle)
            m.C0 = CFrame.new(0, 0, 0) * CFrame.Angles(flap, 0, twist)
        end)
    end)
end

local function gm_removewings(char)
    if char then
        local existing = char:FindFirstChild("Angel Wings")
        if existing then existing:Destroy() end
    end
    if gm_wings_connection then
        gm_wings_connection:Disconnect()
        gm_wings_connection = nil
    end
end

