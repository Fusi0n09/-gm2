local function gm_isbasepart(x)
    return typeof(x) == "Instance" and x:IsA("BasePart")
end

local function gm_ensureprimarypart(model)
    if model and model:IsA("Model") then
        if not gm_isbasepart(model.PrimaryPart) then
            local first = model:FindFirstChildWhichIsA("BasePart")
            if first then model.PrimaryPart = first end
        end
        return model.PrimaryPart
    end
end

local function gm_prepparts(model, isknife)
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
            part.Anchored = false
            part.Massless = true
            part.Transparency = math.clamp(part.Transparency, 0, 1)
        end
        if isknife and part:IsA("MeshPart") then
            local sa = part:FindFirstChildOfClass("SurfaceAppearance")
            if sa then sa:Destroy() end
            if part.TextureID == "" then
                local name = part.Name:lower()
                if name:find("box") or name:find("cube") or name:find("part") or name:find("hit") then
                    part.Transparency = 1
                end
            end
        end
    end
end

local function gm_weldparts(a, b)
    if gm_isbasepart(a) and gm_isbasepart(b) then
        local weld = Instance.new("WeldConstraint")
        weld.Part0 = a
        weld.Part1 = b
        weld.Parent = a
        return weld
    end
end

local function gm_getwrapskinmodel(weaponname, skinname, timeout)
    timeout = timeout or 5
    local wraps = gm_replicatedstorage:WaitForChild("Wraps", timeout)
    if not wraps then return nil end
    local folder = wraps:WaitForChild("[" .. weaponname .. "]", timeout)
    if not folder then return nil end
    if not skinname or skinname == "" then return nil end
    return folder:WaitForChild(skinname, timeout)
end

local function gm_applymodelonholder(holder, skinmodel)
    if not holder or not skinmodel then return end
    local handle = holder:FindFirstChild("Handle")
    if not gm_isbasepart(handle) then return end
    local old = holder:FindFirstChild("SkinModel")
    if old then old:Destroy() end
    local clone = skinmodel:Clone()
    clone.Name = "SkinModel"
    local primarypart = gm_ensureprimarypart(clone)
    if not gm_isbasepart(primarypart) then return end
    local isknife = holder.Name:find("Knife") and true or false
    gm_prepparts(clone, isknife)
    clone.Parent = holder
    clone:PivotTo(handle.CFrame)
    for _, part in ipairs(clone:GetDescendants()) do
        if part:IsA("BasePart") then gm_weldparts(handle, part) end
    end
    handle.Transparency = 1
end

local function gm_applytoolskin(tool)
    if not tool or not tool:IsA("Tool") then return end
    local weaponname = tool.Name:match("^%[(.+)%]$")
    if not weaponname then return end
    local skinname = getgenv().gm_skins[weaponname]
    if not skinname or skinname == "" then return end
    local skinmodel = gm_getwrapskinmodel(weaponname, skinname, 5)
    if skinmodel then gm_applymodelonholder(tool, skinmodel) end
end

local function gm_applyknifeskin(tool)
    if not tool or not tool:IsA("Tool") then return end
    if tool.Name ~= "[Knife]" then return end
    local knifeskin = getgenv().gm_skins.special and getgenv().gm_skins.special["Knife"]
    if not knifeskin or knifeskin == "" then return end
    local knives = gm_replicatedstorage:FindFirstChild("Knives")
    if not knives then return end
    local skinmodel = knives:FindFirstChild(knifeskin)
    if skinmodel then gm_applymodelonholder(tool, skinmodel) end
end

local function gm_applyhandleskin(character, handlefoldername)
    local weaponname = gm_handlemap[handlefoldername]
    if not weaponname then return end
    local skinname = getgenv().gm_skins[weaponname]
    if not skinname or skinname == "" then return end
    local handlefolder = character:FindFirstChild(handlefoldername)
    if not handlefolder then return end
    local skinmodel = gm_getwrapskinmodel(weaponname, skinname, 5)
    if skinmodel then gm_applymodelonholder(handlefolder, skinmodel) end
end

local function gm_applyallskins(character)
    if not getgenv().gm_skins.enabled then return end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            gm_applytoolskin(tool)
            gm_applyknifeskin(tool)
        end
    end
    for handlefoldername, _ in pairs(gm_handlemap) do
        gm_applyhandleskin(character, handlefoldername)
    end
end

local function gm_connectcharacter(character)
    character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            gm_applytoolskin(child)
            gm_applyknifeskin(child)
        elseif gm_handlemap[child.Name] then
            task.defer(function() gm_applyhandleskin(character, child.Name) end)
        end
    end)
    gm_applyallskins(character)
end

